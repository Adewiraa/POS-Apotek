{
	"info": {
		"_postman_id": "d1c0a0c4-1234-4a8b-9e9d-123456789abc",
		"name": "POS Apotek Modern API",
		"description": "Koleksi API lengkap untuk integrasi Frontend (React/Vue) dengan Backend POS Apotek.",
