						"body": {
							"mode": "raw",
							"raw": "{\n  \"cashier_id\": 1,\n  \"patient_id\": 2,\n  \"payment_method\": \"Cash\",\n  \"total_amount\": 50000,\n  \"amount_tendered\": 0,\n  \"discount\": 0,\n  \"tax\": 0,\n  \"items\": [\n    { \"product_id\": 1, \"qty\": 1, \"price\": 50000 }\n  ]\n}"
