	},
	"item": [
		{
			"name": "1. Master Data",
			"item": [
				{
					"name": "Get Products",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/master/products",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "master", "products" ]
						}
					}
				}
			]
		},
		{
			"name": "2. Transaksi POS (Kasir)",
			"item": [
				{
					"name": "Checkout Pembayaran",
