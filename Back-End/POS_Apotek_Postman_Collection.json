							"mode": "raw",
							"raw": "{\n  \"supplier_id\": 1,\n  \"user_id\": 1,\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"batch_no\": \"BCH-123\",\n      \"expired_date\": \"2028-12-01\",\n      \"qty_received\": 500\n    }\n  ]\n}"
